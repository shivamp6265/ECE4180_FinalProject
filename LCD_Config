//File to configure the GPIO pins from the ESP to the LCD to the LGFX library that we found so that it would work
#include <LovyanGFX.hpp>

class LGFX : public lgfx::LGFX_Device {
  lgfx::Panel_ST7796 _panel_instance;
  lgfx::Bus_Parallel8 _bus_instance;

public:
  LGFX(void) {
    { // MCU8080 8-bit parallel bus
      auto cfg = _bus_instance.config();
      cfg.port = 0;                 // ESP32-S3 port
      cfg.freq_write = 20000000;    // setting the write frequency to 20MHz

      // Control pins from the data sheet
      cfg.pin_wr   = 47;  // Write strobe enable
      cfg.pin_rs   = 0;   // register select 
  
      // Data pins from the data sheet
      cfg.pin_d0 = 9;
      cfg.pin_d1 = 46;
      cfg.pin_d2 = 3;
      cfg.pin_d3 = 8;
      cfg.pin_d4 = 18;
      cfg.pin_d5 = 17;
      cfg.pin_d6 = 16;
      cfg.pin_d7 = 15;

      _bus_instance.config(cfg);
      _panel_instance.setBus(&_bus_instance);
    }

    { // Panel configuration settings
      auto cfg = _panel_instance.config();
      cfg.pin_cs   = -1;   // not connected
      cfg.pin_rst  = 4;    // reset
      cfg.pin_busy = -1;
      cfg.panel_width  = 320;
      cfg.panel_height = 480;
      cfg.invert       = false;
      cfg.rgb_order    = false;
      
      _panel_instance.config(cfg);
    }

    setPanel(&_panel_instance);
  }
};
